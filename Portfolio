<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Yash Srivastava — Data Analyst</title>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root {
  --ink: #0d0d0d;
  --paper: #f5f2eb;
  --paper2: #ede9df;
  --gold: #c4922a;
  --gold2: #e8b84b;
  --rust: #c44a2a;
  --teal: #1a6b5a;
  --muted: #7a7060;
  --border: rgba(13,13,13,0.12);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }

body {
  background: var(--paper);
  color: var(--ink);
  font-family: 'Syne', sans-serif;
  overflow-x: hidden;
  cursor: none;
}

/* CURSOR */
#cur { width: 12px; height: 12px; background: var(--gold); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); transition: transform 0.1s; mix-blend-mode: multiply; }
#cur-ring { width: 40px; height: 40px; border: 1px solid var(--gold); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998; transform: translate(-50%,-50%); transition: all 0.15s ease; opacity: 0.6; }
body:hover #cur, body:hover #cur-ring { opacity: 1; }

/* NOISE */
body::after {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 9000; opacity: 0.5;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 24px 60px;
  transition: all 0.5s;
}
nav.stuck {
  background: rgba(245,242,235,0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  padding: 16px 60px;
}
.logo {
  font-family: 'Instrument Serif', serif;
  font-size: 22px; color: var(--ink);
  text-decoration: none; letter-spacing: 0.01em;
}
.logo em { color: var(--gold); font-style: italic; }
.nav-menu { display: flex; gap: 40px; list-style: none; }
.nav-menu a {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: var(--muted);
  text-decoration: none; letter-spacing: 0.12em;
  text-transform: uppercase;
  transition: color 0.3s;
}
.nav-menu a:hover { color: var(--gold); }
.nav-cta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; padding: 9px 22px;
  border: 1px solid var(--ink);
  color: var(--ink); text-decoration: none;
  letter-spacing: 0.1em; text-transform: uppercase;
  transition: all 0.3s;
}
.nav-cta:hover { background: var(--ink); color: var(--paper); }

/* HERO */
#hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  overflow: hidden;
}
.hero-left {
  padding: 140px 60px 80px;
  display: flex; flex-direction: column; justify-content: center;
  border-right: 1px solid var(--border);
}
.hero-right {
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 140px 60px 80px;
  position: relative;
}

/* Big decorative text */
.hero-bg-text {
  position: absolute;
  bottom: -20px; right: -20px;
  font-family: 'Instrument Serif', serif;
  font-size: 260px; line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1px rgba(13,13,13,0.06);
  pointer-events: none;
  user-select: none;
}

.eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: var(--gold);
  letter-spacing: 0.2em; text-transform: uppercase;
  margin-bottom: 28px;
  display: flex; align-items: center; gap: 14px;
  opacity: 0; animation: up 0.9s forwards 0.1s;
}
.eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--gold); }

.hero-name {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(60px, 7.5vw, 108px);
  font-weight: 400; line-height: 0.92;
  letter-spacing: -0.02em;
  margin-bottom: 32px;
  opacity: 0; animation: up 0.9s forwards 0.25s;
}
.hero-name em { font-style: italic; color: var(--gold); }

.hero-desc {
  font-size: 16px; color: var(--muted);
  line-height: 1.8; max-width: 440px;
  font-family: 'Syne', sans-serif; font-weight: 400;
  margin-bottom: 48px;
  opacity: 0; animation: up 0.9s forwards 0.4s;
}
.hero-desc strong { color: var(--ink); font-weight: 600; }

.hero-btns {
  display: flex; gap: 14px; flex-wrap: wrap;
  opacity: 0; animation: up 0.9s forwards 0.55s;
}
.btn-dark {
  padding: 14px 32px; background: var(--ink); color: var(--paper);
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  letter-spacing: 0.1em; text-transform: uppercase;
  text-decoration: none; transition: all 0.3s;
  clip-path: polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,0 100%);
}
.btn-dark:hover { background: var(--gold); }
.btn-outline {
  padding: 14px 32px; background: transparent; color: var(--ink);
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  letter-spacing: 0.1em; text-transform: uppercase;
  text-decoration: none; border: 1px solid var(--border);
  transition: all 0.3s;
}
.btn-outline:hover { border-color: var(--ink); }

/* right side hero */
.hero-stats {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
  border: 1px solid var(--border);
  opacity: 0; animation: up 0.9s forwards 0.6s;
  margin-bottom: 32px;
}
.hero-stat {
  padding: 28px 24px; background: var(--paper);
  transition: background 0.3s;
}
.hero-stat:hover { background: var(--paper2); }
.h-stat-num {
  font-family: 'Instrument Serif', serif;
  font-size: 52px; color: var(--gold);
  line-height: 1; margin-bottom: 6px;
}
.h-stat-label { font-size: 12px; color: var(--muted); line-height: 1.4; }

.hero-certs {
  display: flex; flex-wrap: wrap; gap: 8px;
  opacity: 0; animation: up 0.9s forwards 0.75s;
}
.cert-pill {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; padding: 5px 12px;
  border: 1px solid var(--border); color: var(--muted);
  letter-spacing: 0.06em;
  transition: all 0.3s;
}
.cert-pill:hover { border-color: var(--gold); color: var(--gold); }

/* MARQUEE */
.marquee-wrap {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: var(--ink); overflow: hidden;
  padding: 14px 0;
}
.marquee-track {
  display: flex; gap: 0;
  animation: marquee 22s linear infinite;
  white-space: nowrap;
}
.marquee-item {
  font-family: 'Instrument Serif', serif;
  font-size: 18px; color: var(--paper);
  padding: 0 32px; opacity: 0.7;
  flex-shrink: 0;
}
.marquee-dot { color: var(--gold); opacity: 1 !important; }
@keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* SECTIONS */
section { padding: 100px 60px; }
.s-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--gold);
  letter-spacing: 0.2em; text-transform: uppercase;
  margin-bottom: 12px;
  display: flex; align-items: center; gap: 12px;
}
.s-label::before { content: attr(data-n); color: var(--muted); }
.s-title {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(36px, 4.5vw, 60px);
  font-weight: 400; letter-spacing: -0.02em;
  line-height: 1.05; margin-bottom: 64px;
}

/* ABOUT */
#about { background: var(--paper2); }
.about-layout { display: grid; grid-template-columns: 5fr 4fr; gap: 80px; align-items: start; }
.about-body p { font-size: 16px; color: var(--muted); line-height: 1.85; margin-bottom: 18px; }
.about-body p strong { color: var(--ink); font-weight: 600; }
.about-pull {
  font-family: 'Instrument Serif', serif;
  font-size: 24px; font-style: italic;
  color: var(--ink); line-height: 1.5;
  border-left: 3px solid var(--gold);
  padding-left: 24px; margin: 32px 0;
}
.about-contact { margin-top: 32px; display: flex; flex-direction: column; gap: 10px; }
.a-contact-row {
  display: flex; align-items: center; gap: 12px;
  font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--muted);
}
.a-contact-row span { color: var(--gold); font-size: 14px; }

.about-right { display: flex; flex-direction: column; gap: 2px; }
.a-stat {
  padding: 24px 28px; border: 1px solid var(--border);
  background: var(--paper); display: flex; align-items: center;
  gap: 20px; transition: transform 0.3s, border-color 0.3s;
}
.a-stat:hover { transform: translateX(8px); border-color: var(--gold); }
.a-stat-n {
  font-family: 'Instrument Serif', serif;
  font-size: 44px; color: var(--gold); line-height: 1;
  min-width: 70px;
}
.a-stat-t { font-size: 13px; color: var(--muted); line-height: 1.4; }

/* SKILLS */
#skills { background: var(--paper); }
.skills-layout { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
.sk-group {
  background: var(--paper2); padding: 36px 32px;
  border: 1px solid var(--border);
  transition: border-color 0.3s;
  position: relative; overflow: hidden;
}
.sk-group::before {
  content: attr(data-icon);
  position: absolute; top: -10px; right: 16px;
  font-size: 80px; opacity: 0.04; line-height: 1;
  pointer-events: none;
}
.sk-group:hover { border-color: var(--gold); }
.sk-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 20px;
}
.sk-tags { display: flex; flex-wrap: wrap; gap: 7px; }
.sk-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; padding: 5px 11px;
  border: 1px solid var(--border); color: var(--muted);
  transition: all 0.3s;
}
.sk-group:hover .sk-tag { border-color: rgba(196,146,42,0.3); color: var(--ink); }
.sk-tag.hi { border-color: var(--gold); color: var(--gold); }

/* EXPERIENCE */
#experience { background: var(--paper2); }
.exp-timeline { display: flex; flex-direction: column; gap: 2px; }
.exp-item {
  display: grid; grid-template-columns: 240px 1fr;
  border: 1px solid var(--border);
  background: var(--paper);
  transition: all 0.3s;
  position: relative;
}
.exp-item::after {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 0; background: var(--gold);
  transition: width 0.4s;
}
.exp-item:hover { transform: translateX(6px); }
.exp-item:hover::after { width: 3px; }
.exp-meta { padding: 32px 28px; border-right: 1px solid var(--border); }
.exp-date {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--gold);
  letter-spacing: 0.1em; margin-bottom: 12px;
}
.exp-title { font-size: 17px; font-weight: 600; margin-bottom: 5px; line-height: 1.2; }
.exp-co {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: var(--muted); letter-spacing: 0.05em;
}
.exp-body { padding: 32px 36px; }
.exp-pts { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.exp-pts li {
  font-size: 13px; color: var(--muted);
  line-height: 1.7; padding-left: 18px; position: relative;
}
.exp-pts li::before { content: '▸'; position: absolute; left: 0; color: var(--gold); font-size: 10px; top: 3px; }

/* PROJECTS */
#projects { background: var(--paper); }
.proj-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }
.proj-card {
  background: var(--paper2); border: 1px solid var(--border);
  padding: 44px 40px;
  display: flex; flex-direction: column;
  transition: all 0.3s; position: relative; overflow: hidden;
}
.proj-card::before {
  content: attr(data-num);
  position: absolute; top: -20px; right: 20px;
  font-family: 'Instrument Serif', serif;
  font-size: 120px; color: transparent;
  -webkit-text-stroke: 1px rgba(13,13,13,0.05);
  line-height: 1; pointer-events: none;
}
.proj-card:hover { border-color: var(--gold); transform: translateY(-4px); }
.proj-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--gold);
  letter-spacing: 0.15em; margin-bottom: 18px;
}
.proj-title {
  font-family: 'Instrument Serif', serif;
  font-size: 26px; font-weight: 400;
  margin-bottom: 16px; line-height: 1.2;
}
.proj-desc {
  font-size: 13px; color: var(--muted);
  line-height: 1.75; margin-bottom: 20px; flex: 1;
}
.proj-pts { list-style: none; margin-bottom: 24px; display: flex; flex-direction: column; gap: 5px; }
.proj-pts li { font-size: 12px; color: #8a8070; line-height: 1.6; padding-left: 14px; position: relative; }
.proj-pts li::before { content: '–'; position: absolute; left: 0; color: var(--gold); }
.proj-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 28px; }
.proj-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; padding: 3px 9px;
  background: rgba(196,146,42,0.08);
  border: 1px solid rgba(196,146,42,0.25);
  color: var(--gold); letter-spacing: 0.07em;
}
.proj-foot { display: flex; gap: 10px; }
.proj-link {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; padding: 9px 18px;
  text-decoration: none; letter-spacing: 0.08em;
  transition: all 0.3s;
}
.proj-link.dark { background: var(--ink); color: var(--paper); }
.proj-link.dark:hover { background: var(--gold); }
.proj-link.outline { border: 1px solid var(--border); color: var(--muted); }
.proj-link.outline:hover { border-color: var(--ink); color: var(--ink); }

/* EDUCATION */
#education { background: var(--paper2); }
.edu-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; }
.edu-col-head {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 28px; padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.edu-item { padding: 22px 0; border-bottom: 1px solid var(--border); }
.edu-date { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--gold); letter-spacing: 0.08em; margin-bottom: 7px; }
.edu-deg { font-size: 15px; font-weight: 600; margin-bottom: 3px; }
.edu-sch { font-size: 13px; color: var(--muted); }
.cert-card {
  border: 1px solid var(--border); padding: 20px 22px;
  margin-bottom: 2px; background: var(--paper);
  display: flex; gap: 16px; align-items: flex-start;
  transition: all 0.3s;
}
.cert-card:hover { border-color: var(--gold); transform: translateX(6px); }
.cert-ico {
  width: 38px; height: 38px; background: var(--paper2);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; flex-shrink: 0;
}
.cert-nm { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
.cert-is { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--muted); letter-spacing: 0.05em; }

/* CONTACT */
#contact {
  background: var(--ink); color: var(--paper);
  padding: 120px 60px; position: relative; overflow: hidden;
}
.contact-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 70% 60% at 30% 50%, rgba(196,146,42,0.08), transparent);
  pointer-events: none;
}
.contact-bg2 {
  position: absolute;
  bottom: -60px; right: -40px;
  font-family: 'Instrument Serif', serif;
  font-size: 300px; line-height: 1;
  color: transparent; -webkit-text-stroke: 1px rgba(245,242,235,0.04);
  pointer-events: none; user-select: none;
}
.contact-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
.c-avail {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  color: #4ade80; letter-spacing: 0.1em; margin-bottom: 32px;
}
.c-dot { width: 8px; height: 8px; border-radius: 50%; background: #4ade80; animation: blink 2s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.c-title {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(44px,5.5vw,72px); font-weight: 400;
  line-height: 1.0; letter-spacing: -0.02em; margin-bottom: 20px;
}
.c-title em { color: var(--gold); font-style: italic; }
.c-sub { font-size: 15px; color: #8a8070; line-height: 1.7; }
.c-links { display: flex; flex-direction: column; gap: 12px; }
.c-link {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 24px;
  border: 1px solid rgba(245,242,235,0.1);
  text-decoration: none; color: var(--paper);
  font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 500;
  transition: all 0.3s;
}
.c-link:hover { border-color: var(--gold); background: rgba(196,146,42,0.08); }
.c-link-ico { color: var(--gold); font-size: 18px; }
.c-link span { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #8a8070; }

footer {
  background: var(--ink); border-top: 1px solid rgba(245,242,235,0.08);
  padding: 24px 60px; display: flex; justify-content: space-between; align-items: center;
}
footer p { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #4a4538; letter-spacing: 0.08em; }
footer em { color: var(--gold); font-style: normal; }

/* REVEAL */
.reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.75s ease, transform 0.75s ease; }
.reveal.on { opacity: 1; transform: translateY(0); }

/* ANIMATIONS */
@keyframes up { from{opacity:0;transform:translateY(32px)} to{opacity:1;transform:translateY(0)} }

/* MOBILE */
@media(max-width:900px){
  nav{padding:18px 24px;}
  nav.stuck{padding:14px 24px;}
  .nav-menu,.nav-cta{display:none;}
  #hero{grid-template-columns:1fr;min-height:auto;}
  .hero-left,.hero-right{padding:100px 24px 40px;}
  .hero-left{border-right:none;border-bottom:1px solid var(--border);}
  section{padding:70px 24px;}
  .about-layout,.skills-layout,.proj-grid,.edu-layout,.contact-layout{grid-template-columns:1fr;}
  .exp-item{grid-template-columns:1fr;}
  .exp-meta{border-right:none;border-bottom:1px solid var(--border);}
  footer{flex-direction:column;gap:8px;text-align:center;}
}
</style>
</head>
